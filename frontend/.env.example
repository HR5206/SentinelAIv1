# SentinelAI Frontend Environment Variables

# Backend URLs
# The FastAPI app runs on port 8000 for voice/interactive turn handling
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# The core Flask app factory runs on port 5001 for all main endpoints
NEXT_PUBLIC_FLASK_API_URL=http://localhost:5001

# Mapbox token for the Bengaluru Map visualization
# You MUST set a valid Mapbox token here for the map to load
NEXT_PUBLIC_MAPBOX_TOKEN=
